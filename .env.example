# SQLite connection string consumed by SQLx at server startup.
DATABASE_URL=sqlite://data/todomvc.db

# Address where the Leptos/Axum server listens.
LEPTOS_SITE_ADDR=0.0.0.0:8080

# Runtime path used by cargo-leptos for generated site assets.
LEPTOS_SITE_ROOT=target/site

# Standard Rust log filter for server logs.
RUST_LOG=info
